#: freerec.graph.to_normalized:1 of
msgid "Normalize edge weights using degree-based normalization."
msgstr ""

#: freerec.graph.to_normalized:3 of
msgid "Supports symmetric square-root, left-side, and right-side normalization:"
msgstr ""

#: freerec.graph.to_normalized:5 of
msgid ""
"\\text{sym:}   \\quad \\tilde{\\mathbf{A}} = "
"\\mathbf{D}_l^{-1/2}\\,\\mathbf{A}\\,\\mathbf{D}_r^{-1/2}\n"
"\n"
"\\text{left:}  \\quad \\tilde{\\mathbf{A}} = "
"\\mathbf{D}_l^{-1}\\,\\mathbf{A}\n"
"\n"
"\\text{right:} \\quad \\tilde{\\mathbf{A}} = "
"\\mathbf{A}\\,\\mathbf{D}_r^{-1}"
msgstr ""

